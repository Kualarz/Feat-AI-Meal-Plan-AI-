// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  password    String?
  name      String?
  avatarUrl String?
  createdAt DateTime     @default(now())
  preferences Preference[]
  plans     Plan[]
  savedRecipes        SavedRecipe[]
  collections         Collection[]
  likes               Like[]
  passwordResetTokens PasswordResetToken[]
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
}

model Collection {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  savedRecipes SavedRecipe[]
}

model SavedRecipe {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId     String
  recipe       Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@unique([userId, recipeId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Preference {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caloriesTarget      Int?
  proteinTarget       Int?
  diet                String   // balanced, vegetarian, vegan, pescatarian, keto
  halalEnabled        Boolean  @default(false)
  vegetarianEnabled   Boolean  @default(false)
  veganEnabled        Boolean  @default(false)
  currentWeight       Float?   // in kg
  targetWeight        Float?   // in kg
  weightGoal          String?  // lose, maintain, gain
  height              Float?   // in cm
  age                 Int?     // in years
  activityLevel       String?  // sedentary, light, moderate, very_active, extremely_active

  allergens           String?  // CSV
  dislikes            String?  // CSV
  cuisines            String?  // CSV, default to "Cambodian,Thai,Vietnamese"
  timeBudgetMins      Int?
  budgetLevel         String?  // low, medium, high
  equipment           String?  // CSV
  region              String?  // e.g. KH, AU
  currency            String?  // e.g. KHR, AUD
  useImperial         Boolean  @default(false)
  showCalories        Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model Recipe {
  id              String     @id @default(cuid())
  title           String
  description     String?
  cuisine         String?
  dietTags        String?    // CSV: vegetarian, vegan, halal, etc.
  difficulty      String?    // easy/medium/hard
  timeMins        Int?
  estimatedPrice  Float?
  currency        String?
  kcal            Int?
  proteinG        Int?
  carbsG          Int?
  fatG            Int?
  fiberG          Int?
  sugarG          Int?
  sodiumMg        Int?
  ingredientsJson String     // JSON string of [{name,qty,unit,notes}]
  stepsMd         String     // Markdown
  safetyMd        String?    // Markdown
  imageUrl        String?
  sourceUrl       String?
  cookwareJson    String?    // JSON string of string[] e.g. ["Wok","Cutting board"]
  imagePrompt      String?
  tags            String?    // CSV
  rating          Float?     @default(0)
  createdAt       DateTime   @default(now())
  planMeals       PlanMeal[]
  likes           Like[]
  savedBy         SavedRecipe[]
}

model Plan {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime
  weekEnd   DateTime
  createdAt DateTime   @default(now())
  meals     PlanMeal[]
}

model PlanMeal {
  id       String  @id @default(cuid())
  planId   String
  plan     Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  dateISO  String? // null when slot = "queue"
  slot     String  // breakfast, lunch, dinner, dessert, queue
  recipeId String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id])
  notes    String?
}

model CuratedCollection {
  id          String   @id @default(cuid())
  title       String
  emoji       String
  tagline     String
  recipeIds   String   // JSON array of recipe IDs e.g. '["id1","id2"]'
  generatedAt DateTime @default(now())
}
